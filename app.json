{
  "expo": {
    "name": "Goldride",
    "slug": "goldride-taxi",
    "owner": "isa.dev",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "goldride",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "uz.goldride.app",
      "buildNumber": "1.0.0",
      "config": {
        "googleMapsApiKey": "AIzaSyDummyKey_For_Build_Stability"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Goldride sizga yaqin haydovchilarni ko'rsatish va buyurtma berishingiz uchun joylashuvingizdan foydalanadi.",
        "NSLocationAlwaysUsageDescription": "Haydovchi sifatida mijozlarga joylashuvingizni ko'rsatish uchun doimiy ruxsat kerak.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Safar davomida xavfsizlik va monitoring uchun joylashuv ma'lumotlari kerak.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "uz.goldride.app",
      "versionCode": 3,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDummyKey_For_Build_Stability"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Taksi xizmati uchun joylashuvingiz kerak."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil rasmi uchun kerak."
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "96a849f5-05a5-4e2e-91e3-017d3010fb2a"
      }
    }
  }
}
