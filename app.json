{
  "expo": {
    "name": "Goldride",
    "slug": "goldride-taxi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "goldride",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "uz.goldride.app",
      "associatedDomains": [
        "applinks:goldride.taxi"
      ],
      "buildNumber": "1.0.0",
      "config": {
        "googleMapsApiKey": "AIzaSyB6V_8tf-pSO3nD6GggpAMI0LVPgmZrUk4"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Goldride sizga yaqin haydovchilarni ko'rsatish va buyurtma berishingiz uchun joylashuvingizdan foydalanadi.",
        "NSLocationAlwaysUsageDescription": "Haydovchi sifatida mijozlarga joylashuvingizni ko'rsatish uchun doimiy ruxsat kerak.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Safar davomida xavfsizlik va monitoring uchun joylashuv ma'lumotlari kerak.",
        "UIBackgroundModes": [
          "location",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "uz.goldride.app",
      "versionCode": 3,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "goldride.taxi",
              "pathPrefix": "/invite"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB6V_8tf-pSO3nD6GggpAMI0LVPgmZrUk4"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Taksi xizmati uchun joylashuvingiz kerak."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil rasmi uchun kerak."
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "telegramApiId": "29523743",
      "telegramApiHash": "d7ae79c4f5ccae4de114695624ec3456",
      "eas": {
        "projectId": "e5ede81d-cc5a-43fc-bcf0-4e756d90e3a7"
      }
    }
  }
}
